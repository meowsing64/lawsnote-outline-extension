{
  "manifest_version": 3,
  "name": "Lawsnote 判決大綱導航",
  "version": "1.0.0",
  "description": "在 Lawsnote 判決頁面顯示可點擊的判決結構大綱，快速跳轉到主文、事實、理由等各段落。由喵星律師（宸星法律事務所）開發，經 Lawsnote 授權同意。",
  "author": "喵星律師（宸星法律事務所）",
  "homepage_url": "https://github.com/meowsing-lawyer/lawsnote-outline-extension",
  "permissions": [],
  "content_scripts": [
    {
      "matches": [
        "https://lawsnote.com/judgement/*",
        "https://www.lawsnote.com/judgement/*",
        "https://atlas.lawsnote.com/judgement/*"
      ],
      "js": ["content.js"],
      "css": ["sidebar.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
